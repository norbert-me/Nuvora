# Kopieren nach .deploy.env und eintragen. .deploy.env ist gitignored.
# Diese Datei ist die Wahrheit fuer das Deployment: PORT und SITE_URL werden
# bei jedem ./deploy.sh auf den Server geschrieben. Secrets stehen NICHT hier,
# die leben nur in der .env auf dem Server.

SERVER="root@dein-server"
REMOTE_DIR="/pfad/auf/dem/server/nuvora"

# Port, unter dem Nuvora erreichbar ist. Aenderbar per `./deploy.sh --port 8090`,
# das den Wert hier gleich mitschreibt.
PORT=8080

# Oeffentliche Basis-URL (Links in E-Mails, CORS). Leer lassen = aus SERVER
# und PORT ableiten. Mit Port drin zieht --port automatisch mit; eine Domain
# ohne Port (hinter Reverse Proxy) bleibt unangetastet.
SITE_URL=""
