# ─── Secrets: niemals committen ───
.env
.env.*
!.env.example
*.env.local
*.env.production
.deploy.env
!.deploy.env.example
*.pem
*.key
*.p12
.htpasswd
secrets/

# ─── Personenbezogene Daten (DSGVO) ───
# Datenbanken enthalten Schülerdaten und Passwort-Hashes.
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
backups/
uploads/
# Achtung: apps/lernpfad/daten/ ist KEIN Nutzerdatenverzeichnis, sondern
# Seed-Aufgaben, die der Docker-Build braucht (loadInitialData in server.js).
# Laufzeit-Datenverzeichnisse (Bind-Mounts). Bewusst NICHT das breite "data/",
# das auch Quellordner wie apps/code-detektiv/src/data trifft — DB-Dateien sind
# ohnehin ueber *.db erfasst.
/data/
apps/*/data/

# ─── Betreiber-/Rechtskonfiguration ───
# Eine Quelle fuer beide Module: enthaelt die private Anschrift des Betreibers.
config/site.json
!config/site.example.json

# ─── Dependencies ───
node_modules/
__pycache__/
*.pyc
.venv/
venv/

# ─── Build-Output ───
dist/
build/

# ─── IDE & Tools ───
.vscode/
.idea/
.claude/
*.swp
*~

# ─── OS ───
.DS_Store
Thumbs.db
@eaDir/

# ─── Sonstiges ───
*.log
*.bak
*.doc
*.docx
*.xlsx
*.bundle
~$*
