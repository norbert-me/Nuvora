# Copy to .env and adjust values
TOKEN_SECRET=change-me-to-a-random-string
POSTGRES_USER=cardvote
POSTGRES_PASSWORD=cardvote
POSTGRES_DB=cardvote
CORS_ORIGINS=http://localhost:3001
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Öffentliche Basis-URL (für Links in E-Mails, z.B. Passwort-Reset)
SITE_URL=

# E-Mail-Versand (SMTP) — provider-neutral. Beispiel Cloudflare Email:
#   SMTP_HOST=smtp.mx.cloudflare.net
#   SMTP_PORT=465
#   SMTP_USER=api_token
#   SMTP_PASSWORD=<dein-cloudflare-api-token>   # NICHT identisch mit TOKEN_SECRET!
#   SMTP_FROM=welcome@deinedomain.de
# Leer lassen = kein Mailversand (App läuft normal weiter)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=CardVote

# Öffentliche Basis-URL (für Links in E-Mails, z.B. Passwort-Reset)
SITE_URL=

# E-Mail-Versand (SMTP) — provider-neutral. Beispiel Cloudflare Email:
#   SMTP_HOST=smtp.mx.cloudflare.net
#   SMTP_PORT=465
#   SMTP_USER=api_token
#   SMTP_PASSWORD=<API_TOKEN>
#   SMTP_FROM=welcome@deinedomain.de
# Leer lassen = kein Mailversand (App läuft normal, nur ohne E-Mails).
SMTP_HOST=
