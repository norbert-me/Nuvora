# Kopieren nach .env und ausfuellen. .env ist gitignored.
#
# Beim Deploy legt ./deploy.sh die .env auf dem Server automatisch an und
# wuerfelt TOKEN_SECRET und POSTGRES_PASSWORD selbst aus — dort muss nichts
# von Hand gesetzt werden. Diese Datei von Hand ausfuellen ist nur noetig,
# wenn der Stack lokal laufen soll.

# Port, unter dem Nuvora erreichbar ist
PORT=8080
SITE_URL=http://localhost:8080

# Postgres
POSTGRES_USER=nuvora
POSTGRES_PASSWORD=   # PFLICHT (lokal): `openssl rand -hex 24`
POSTGRES_DB=nuvora

# PFLICHT (lokal): `openssl rand -hex 32`
TOKEN_SECRET=

# Admin-Konto (beide Module erkennen den Admin an dieser Adresse)
ADMIN_EMAIL=admin
ADMIN_PASSWORD=admin

# E-Mail-Versand (Registrierung, Passwort-Reset).
# Leer lassen = kein Mailversand, App laeuft normal weiter.
# Beispiel Cloudflare Email:
#   SMTP_HOST=smtp.mx.cloudflare.net
#   SMTP_PORT=465
#   SMTP_USER=api_token
#   SMTP_PASSWORD=<API-Token>   # NICHT identisch mit TOKEN_SECRET
#   SMTP_FROM=welcome@deine-domain.de
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=Nuvora
